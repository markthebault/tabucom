<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Protected page · Tabucom</title>
  <style>
    :root{color-scheme:light;--ink:#17201f;--muted:#5e6966;--paper:#f5f1e9;--line:#d9d3c7;--accent:#0c7569;--error:#a33b24}
    *{box-sizing:border-box}
    body{min-height:100svh;margin:0;display:grid;place-items:center;padding:24px;color:var(--ink);background:radial-gradient(circle at 88% 18%,#f7cdb7 0,transparent 30%),linear-gradient(145deg,#e2f2e9,#f7f0e5 66%);font:16px/1.5 ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}
    dialog[open]{position:relative;width:min(440px,100%);margin:0;padding:clamp(24px,6vw,38px);border:1px solid rgba(23,32,31,.12);border-radius:22px;background:rgba(255,255,255,.9);color:inherit;box-shadow:0 24px 70px rgba(38,53,49,.18)}
    .eyebrow{margin:0 0 10px;color:var(--accent);font-size:.75rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase}
    h1{margin:0;font:700 clamp(2rem,8vw,2.8rem)/1 Georgia,serif;letter-spacing:-.035em}
    .lede{margin:16px 0 26px;color:var(--muted)}
    form{display:grid;gap:14px}
    label{font-size:.86rem;font-weight:750}
    input{width:100%;min-height:50px;margin-top:7px;padding:11px 14px;border:1px solid #aeb8b4;border-radius:11px;background:#fff;color:var(--ink);font:inherit;font-size:1rem}
    input:focus-visible{outline:3px solid rgba(12,117,105,.22);border-color:var(--accent)}
    button{min-height:50px;border:0;border-radius:11px;background:var(--accent);color:#fff;font:inherit;font-weight:800;cursor:pointer}
    button:hover{background:#095f56}
    button:focus-visible{outline:3px solid rgba(12,117,105,.3);outline-offset:3px}
    .error{margin:0 0 18px;padding:11px 13px;border-left:4px solid var(--error);border-radius:7px;background:#fff0ec;color:#752b1b;font-size:.9rem}
    @media(max-width:480px){body{padding:16px}dialog[open]{border-radius:18px}}
    @media(prefers-reduced-motion:no-preference){dialog[open]{animation:arrive .2s ease-out}@keyframes arrive{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}}
  </style>
</head>
<body>
  <dialog open aria-labelledby="title" aria-describedby="description">
    <p class="eyebrow">Tabucom · private preview</p>
    <h1 id="title">This page is protected.</h1>
    <p class="lede" id="description">Enter the password shared with you to continue.</p>
    {{if .}}<p class="error" role="alert">{{.}}</p>{{end}}
    <form method="post">
      <label for="password">Password
        <input id="password" name="password" type="password" autocomplete="current-password" required autofocus>
      </label>
      <button type="submit">Unlock page</button>
    </form>
  </dialog>
</body>
</html>
