{
  "openapi": "3.1.0",
  "info": {
    "title": "Tabucom API",
    "version": "1.0.0",
    "description": "Publish HTML, Markdown, or a ZIP containing a prebuilt static site with optional single-password protection. Deployments expire at the client-requested TTL or after the default 30-day retention window when omitted. Uploaded code is never executed."
  },
  "servers": [{"url": "/", "description": "Current service origin"}],
  "externalDocs": {"description": "Complete publishing guide", "url": "/agents"},
  "paths": {
    "/api/v1/publish": {
      "post": {
        "operationId": "publish",
        "summary": "Publish an immutable temporary static site",
        "description": "Send one raw request body. ZIP files must contain index.html at their root. Build source projects before calling this endpoint. Returns only after atomic publication.",
        "parameters": [
          {
            "name": "spa",
            "in": "query",
            "required": false,
            "description": "Set to 1 to serve index.html for paths that do not match a real file.",
            "schema": {"type": "string", "enum": ["0", "1"], "default": "0"}
          },
          {
            "name": "ttl",
            "in": "query",
            "required": false,
            "description": "Optional deployment lifetime as a Go-style duration such as 72h or 90m. Defaults to 720h when omitted.",
            "schema": {"type": "string", "examples": ["72h", "90m", "168h"]}
          },
          {
            "name": "prefix",
            "in": "query",
            "required": false,
            "description": "Optional readable ID prefix. The final deployment ID is prefix plus a random 16-hex-character suffix. Prefixes must be 1 to 46 lowercase letters, numbers, or hyphens, and must start and end with a letter or number.",
            "schema": {"type": "string", "minLength": 1, "maxLength": 46, "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$", "examples": ["my-super-website"]}
          },
          {
            "name": "generatePassword",
            "in": "query",
            "required": false,
            "description": "Set to 1 to generate a 24-character visitor password. Cannot be combined with Tabucom-Password.",
            "schema": {"type": "string", "enum": ["0", "1"], "default": "0"}
          },
          {
            "name": "Tabucom-Password",
            "in": "header",
            "required": false,
            "description": "Custom visitor password containing 8 to 128 printable ASCII characters. Never put custom passwords in URLs.",
            "schema": {"type": "string", "minLength": 8, "maxLength": 128}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "text/html": {"schema": {"type": "string", "contentMediaType": "text/html"}},
            "text/markdown": {"schema": {"type": "string", "contentMediaType": "text/markdown"}},
            "application/zip": {"schema": {"type": "string", "format": "binary", "contentMediaType": "application/zip"}}
          }
        },
        "responses": {
          "201": {
            "description": "Published",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PublishResponse"}, "example": {"id":"my-super-website-1a2b3c4d5e6f7890","url":"{{ORIGIN}}/p/my-super-website-1a2b3c4d5e6f7890/","createdAt":"2026-06-19T14:30:00Z","expiresAt":"2026-06-22T14:30:00Z","files":37,"bytes":1842032,"spa":true,"protected":true,"password":"generated-or-custom-password"}}}
          },
          "401": {"$ref": "#/components/responses/ClientError"},
          "400": {"$ref": "#/components/responses/ClientError"},
          "413": {"$ref": "#/components/responses/ClientError"},
          "415": {"$ref": "#/components/responses/ClientError"},
          "429": {"$ref": "#/components/responses/ClientError"},
          "500": {"$ref": "#/components/responses/ServerError"},
          "503": {"$ref": "#/components/responses/ServerError"}
        }
      }
    },
    "/healthz": {
      "get": {
        "operationId": "health",
        "summary": "Check service readiness",
        "responses": {"200": {"description": "Service and storage are ready", "content": {"application/json": {"schema": {"type":"object","additionalProperties":true}}}}, "503": {"description": "Service is not ready"}}
      }
    },
    "/p/{id}/{path}": {
      "get": {
        "operationId": "getPublishedFile",
        "summary": "Read a file from a path-mode deployment",
        "parameters": [
          {"name":"id","in":"path","required":true,"schema":{"type":"string","pattern":"^(?:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}|[a-z0-9](?:[a-z0-9-]*[a-z0-9])?-[0-9a-f]{16})$"}},
          {"name":"path","in":"path","required":true,"schema":{"type":"string"},"description":"File path relative to the deployment root; use an empty suffix for index.html."}
        ],
        "responses": {"200":{"description":"Published static content"},"401":{"description":"Password form for a protected deployment"},"404":{"description":"Deployment not found, expired, or missing the requested file"}}
      },
      "post": {
        "operationId": "unlockPublishedSite",
        "summary": "Unlock a password-protected deployment in a browser",
        "parameters": [
          {"name":"id","in":"path","required":true,"schema":{"type":"string","pattern":"^(?:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}|[a-z0-9](?:[a-z0-9-]*[a-z0-9])?-[0-9a-f]{16})$"}},
          {"name":"path","in":"path","required":true,"schema":{"type":"string"}}
        ],
        "requestBody": {"required":true,"content":{"application/x-www-form-urlencoded":{"schema":{"type":"object","required":["password"],"properties":{"password":{"type":"string"}}}}}},
        "responses": {"303":{"description":"Password accepted; an HttpOnly cookie was set and the browser is redirected"},"401":{"description":"Incorrect password"},"429":{"description":"Too many password attempts"}}
      }
    }
  },
  "components": {
    "schemas": {
      "PublishResponse": {"type":"object","required":["id","url","createdAt","expiresAt","files","bytes","spa","protected"],"properties":{"id":{"type":"string","description":"A UUID by default, or prefix plus a random 16-hex-character suffix when prefix is supplied."},"url":{"type":"string","format":"uri"},"createdAt":{"type":"string","format":"date-time"},"expiresAt":{"type":"string","format":"date-time","description":"CreatedAt plus the requested ttl, or 720 hours when ttl is omitted."},"files":{"type":"integer","minimum":1},"bytes":{"type":"integer","minimum":0},"spa":{"type":"boolean"},"protected":{"type":"boolean"},"password":{"type":"string","description":"Present for protected deployments, including custom-password requests."}}},
      "Error": {"type":"object","required":["error"],"properties":{"error":{"type":"object","required":["code","message"],"properties":{"code":{"type":"string","enum":["empty_body","invalid_archive","invalid_generate_password","invalid_password","invalid_prefix","invalid_spa","invalid_ttl","internal_error","method_not_allowed","missing_index","rate_limited","service_unavailable","too_many_files","unauthorized","unsupported_media_type","upload_too_large"]},"message":{"type":"string"}}}}}
    },
    "responses": {
      "ClientError": {"description":"The upload was rejected", "content":{"application/json":{"schema":{"$ref":"#/components/schemas/Error"}}}},
      "ServerError": {"description":"The service cannot publish right now", "content":{"application/json":{"schema":{"$ref":"#/components/schemas/Error"}}}}
    }
  }
}
